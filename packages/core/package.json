{
  "name": "@intl-ai/core",
  "version": "0.2.0",
  "description": "DEPRECATED — re-exports from @intl-ai/api plus legacy loadConfig(). Migrate to @intl-ai/api.",
  "keywords": [
    "ai",
    "i18n",
    "internationalization",
    "intl",
    "translation"
  ],
  "homepage": "https://intl-ai.illo.fyi/",
  "bugs": "https://github.com/espetro/intl-ai/issues",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+git+https://github.com/sigilco/intl-ai.git"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@intl-ai/api": "workspace:*",
    "jiti": "2.7.0",
    "pathe": "2.0.3"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@types/node": "^22.0.0",
    "tsdown": "0.21.10",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
